{
  "name": "@estate-scraper/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production node dist/index.js",
    "scan": "tsx src/scan/index.ts",
    "embed": "tsx src/scan/embed-only.ts",
    "backfill:items": "tsx src/scan/backfill-items.ts",
    "import": "tsx src/import/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx eval/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "better-sqlite3": "^11.9.1",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.7.10",
    "jose": "^6.2.3",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
