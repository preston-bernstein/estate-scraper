# Auth mode: stub | forwarded | jwt
# stub = always authenticated as dev-user (local dev default)
# forwarded = read x-authentik-uid header (nginx forward auth)
# jwt = validate Bearer token via OIDC JWKS (production default)
AUTH_MODE=jwt

# Required when AUTH_MODE=jwt
# Trailing slash required — must match Authentik provider issuer exactly
OIDC_ISSUER=https://auth.example.com/application/o/estate-scraper/

# SQLite database path (default: ./data/estate-scraper.db)
# DATABASE_URL=./data/estate-scraper.db

# Ollama vision host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Home address — center of geographic search radius
HOME_ADDRESS=123 Main Street
HOME_CITY=Your City
HOME_STATE=XX
HOME_ZIP=00000
HOME_LAT=0.000000
HOME_LON=0.000000

# Oracle escalation — OpenAI-compatible API for uncertain-zone sales (RunPod, Together, Hyperbolic, etc.)
# If unset, oracle is disabled and uncertain-zone sales are kept without escalation.
# ORACLE_API_BASE=https://api.runpod.ai/v2/.../openai
# ORACLE_API_KEY=your_key
# ORACLE_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
