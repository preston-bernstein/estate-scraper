# Authentik OIDC settings — leave unset for local dev (stub auth)
# Get Client ID from: Authentik → Providers → estate-scraper provider
# Issuer URL: https://<authentik-domain>/application/o/<app-slug>/

VITE_OIDC_AUTHORITY=https://auth.example.com/application/o/estate-scraper/
VITE_OIDC_CLIENT_ID=<client-id-from-authentik>
VITE_OIDC_REDIRECT_URI=https://estate-scraper.your-domain.example.com/callback
VITE_OIDC_POST_LOGOUT_URI=https://estate-scraper.your-domain.example.com/
