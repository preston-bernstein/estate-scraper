# Auth mode: stub | forwarded | jwt
# stub = always authenticated as dev-user — LOCAL DEV ONLY, refused at startup when
#        NODE_ENV=production. Use this to get a fresh clone running immediately.
# forwarded = trust x-authentik-uid (etc.) headers, gated by PROXY_SHARED_SECRET —
#        requires the reverse proxy to inject that secret; never expose the app
#        directly on a network where it isn't (bind to loopback behind the proxy).
# jwt = validate Bearer token via OIDC JWKS (production default)
AUTH_MODE=stub

# Required when AUTH_MODE=jwt. Both are pinned during verification — an unpinned
# issuer/audience lets a token minted for any other app on the same IdP impersonate
# a user here (see CVE-2025-62610).
# Trailing slash required — must match Authentik provider issuer exactly
OIDC_ISSUER=https://auth.example.com/application/o/estate-scraper/
OIDC_AUDIENCE=estate-scraper
# OIDC_ALGORITHMS=RS256

# Required when AUTH_MODE=forwarded. Must match the secret the reverse proxy sends
# as x-proxy-secret on every forwarded request; without this check the identity
# headers are trivially spoofable by anything that can reach the app.
# PROXY_SHARED_SECRET=

# Browser origins allowed to call the API cross-origin (comma-separated).
# CORS_ORIGIN=http://localhost:5173

# SQLite database path (default: ./data/estate-scraper.db)
# DATABASE_URL=./data/estate-scraper.db

# Ollama vision host — routes through the ollama-resource-broker, never raw :11434
# (default: http://localhost:11436)
# OLLAMA_HOST=http://localhost:11436

# Home address — center of geographic search radius. Timezone determines the
# household-local "today" used to decide whether a sale is still upcoming.
HOME_ADDRESS=123 Main Street
HOME_CITY=Your City
HOME_STATE=XX
HOME_ZIP=00000
HOME_LAT=0.000000
HOME_LON=0.000000
HOME_TIMEZONE=America/New_York

# Full vision managed API — OpenAI-compatible endpoint replaces local Ollama for the analysis pass.
# Local PASS/SKIP gate still runs on local Ollama regardless. Leave unset for fully local operation.
#
# Gemini 2.5 Flash (recommended — best value, native multimodal, ~$0.03-0.06/sale):
# VISION_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# VISION_API_KEY=<gemini_api_key>
# VISION_API_MODEL=gemini-2.5-flash
#
# RunPod vLLM (open-source; needs network volume pre-loaded with model weights):
# VISION_API_BASE=https://api.runpod.ai/v2/<endpoint_id>/openai/v1
# VISION_API_KEY=<runpod_api_key>
# VISION_API_MODEL=Qwen/Qwen3-VL-32B-Instruct

# RunPod management API key for watchdog podStop calls, distinct from VISION_API_KEY
# (the inference-wire key). Only required when using RunPod backend with automated watchdog.
# RUNPOD_API_KEY=<runpod_api_key>

# Pod name (exact match or strict "<match>-*" prefix, never a loose substring — a
# shared RunPod account risks stopping a sibling project's pod otherwise) the watchdog
# looks for among RUNNING pods before calling podStop. Defaults to estate-scraper-vision
# when unset.
# RUNPOD_POD_NAME_MATCH=estate-scraper-vision

# Staleness/crash guard, in hours. If the watchdog finds scan-state.json's
# phase still "analyzing" but startedAt older than this many hours, it treats
# the Scan as crashed (SIGKILL, OOM, host reboot — died without resetting
# state) and stops the pod anyway. Required — no built-in default; the
# watchdog fails loud at startup if this is unset or not a positive integer.
# 6h is well over a normal Scan's runtime, well under the ADR-0010 full
# reference pass's ~23h.
# WATCHDOG_MAX_SCAN_HOURS=6

# Oracle escalation — called only for uncertain-zone sales (score between ORACLE_SCORE_MIN and MAX).
# Uses OpenAI-compatible Bearer auth. For Claude route through OpenRouter.
# If unset, oracle is disabled and uncertain-zone sales proceed without escalation.
#
# Claude Sonnet 4.6 via Anthropic direct (recommended — best for kitsch/vintage cultural knowledge):
# ORACLE_API_BASE=https://api.anthropic.com
# ORACLE_API_KEY=<anthropic_api_key>
# ORACLE_MODEL=claude-sonnet-4-6
#
# Gemini 2.5 Pro direct (cheaper alternative, OpenAI-compatible):
# ORACLE_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# ORACLE_API_KEY=<gemini_api_key>
# ORACLE_MODEL=gemini-2.5-pro

# Image embeddings — OpenAI-compatible /embeddings endpoint for the durable corpus
# (ADR 0013/0016). Point at the broker's image-embedding lane (:11438), which fronts
# an Infinity SigLIP server on CPU, arbitrates it against gaming/Plex, and rewrites
# /embeddings -> Infinity's /embeddings_image. Never raw Ollama (can't serve SigLIP).
# No /v1 suffix — the lane maps both /embeddings and /v1/embeddings. If EMBED_API_BASE
# is unset the post-scan embed pass is skipped (thumbnails still saved).
# The model is FROZEN: every vector in the column must share one geometry — changing
# it is a re-embed migration, not an append. EMBED_DIM guards against a wrong-dim
# response silently poisoning the column.
# EMBED_API_BASE=http://10.0.0.243:11438
# EMBED_API_KEY=
# EMBED_MODEL=siglip-so400m-patch14-384
# EMBED_DIM=1152
# EMBED_BATCH=16
# EMBED_WORKERS=1   # broker embed lane is concurrency-1 (Infinity saturates all CPU cores)

# Thumbnail storage — durable downscaled JPEGs, one per analyzed image. Also the
# canonical re-embed source (ADR 0016), so this must persist (NAS mount in prod).
# THUMBNAIL_DIR=./data/thumbnails

# Stealth-sidecar (scraper-commons) browser-automation service — local-loopback
# only, never a public address (client refuses anything outside
# localhost/127.0.0.1/private-network ranges).
STEALTH_SIDECAR_URL=http://127.0.0.1:8000
