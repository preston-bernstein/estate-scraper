# Auth mode: stub | forwarded | jwt
# stub = always authenticated as dev-user (local dev default)
# forwarded = read x-authentik-uid header (nginx forward auth)
# jwt = validate Bearer token via OIDC JWKS (production default)
AUTH_MODE=jwt

# Required when AUTH_MODE=jwt
# Trailing slash required — must match Authentik provider issuer exactly
OIDC_ISSUER=https://auth.example.com/application/o/estate-scraper/

# SQLite database path (default: ./data/estate-scraper.db)
# DATABASE_URL=./data/estate-scraper.db

# Ollama vision host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Home address — center of geographic search radius
HOME_ADDRESS=123 Main Street
HOME_CITY=Your City
HOME_STATE=XX
HOME_ZIP=00000
HOME_LAT=0.000000
HOME_LON=0.000000

# Oracle escalation — OpenAI-compatible API for uncertain-zone sales (RunPod, Together, Hyperbolic, etc.)
# If unset, oracle is disabled and uncertain-zone sales are kept without escalation.
# ORACLE_API_BASE=https://api.runpod.ai/v2/.../openai
# ORACLE_API_KEY=your_key
# ORACLE_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# Image embeddings — OpenAI-compatible /embeddings endpoint for the durable corpus
# (ADR 0013/0016). Point at the broker batch port in prod (never raw Ollama). If
# EMBED_API_BASE is unset the post-scan embed pass is skipped (thumbnails still saved).
# The model is FROZEN: every vector in the column must share one geometry — changing
# it is a re-embed migration, not an append. EMBED_DIM guards against a wrong-dim
# response silently poisoning the column.
# EMBED_API_BASE=http://10.0.0.243:11436/v1
# EMBED_API_KEY=
# EMBED_MODEL=siglip-so400m-patch14-384
# EMBED_DIM=1152
# EMBED_BATCH=16
# EMBED_WORKERS=2

# Thumbnail storage — durable downscaled JPEGs, one per analyzed image. Also the
# canonical re-embed source (ADR 0016), so this must persist (NAS mount in prod).
# THUMBNAIL_DIR=./data/thumbnails
