<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.estate-scraper.scan</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_ROOT__/scripts/run-scan.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>4</integer>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__PROJECT_ROOT__/api/data/launchagent.out.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_ROOT__/api/data/launchagent.err.log</string>
  <key>WorkingDirectory</key>
  <string>__PROJECT_ROOT__</string>
</dict>
</plist>
